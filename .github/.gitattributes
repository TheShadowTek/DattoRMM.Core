# Global defaults
* text=auto eol=crlf

# PowerShell files — keep BOM and improve diffs
*.ps1  text eol=crlf diff=powershell
*.psm1 text eol=crlf diff=powershell
*.psd1 text eol=crlf diff=powershell

# Markdown — normal text behaviour
*.md text eol=crlf

# JSON / YAML — normal text behaviour
*.json text eol=crlf
*.yml  text eol=crlf
*.yaml text eol=crlf

# GitHub workflows
.github/**/*.yml text eol=crlf

# Treat these as binary (no diff noise)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.exe binary
*.dll binary
