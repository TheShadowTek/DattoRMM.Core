  <Type>
    <Name>DRMMActivityLogSite</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>if ($this.Name) {$this.Name} else {"Site $($this.Id)"}</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMActivityLogUser</Name>
    <Members>
      <ScriptMethod>
