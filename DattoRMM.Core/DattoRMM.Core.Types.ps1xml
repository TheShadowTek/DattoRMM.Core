  <!-- Network Domain                                                        -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->

  <Type>
    <Name>DRMMNetworkInterface</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $Inst = if ($this.Instance) {$this.Instance} else {'NIC'}
          $Ip = if ($this.Ipv4) {" ($($this.Ipv4))"} else {''}
          "$Inst$Ip"
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMNetMapping</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>if ($this.Name) {$this.Name} else {"NetMapping $($this.Uid)"}</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- Printer Audit Domain                                                  -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->

  <Type>
    <Name>DRMMPrinterAudit</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $Info = if ($this.SystemInfo) {"$($this.SystemInfo.Manufacturer) $($this.SystemInfo.Model)"} else {$null}
          if ($Info) {"$($this.DeviceUid) - $Info"} else {"$($this.DeviceUid)"}
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMPrinter</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>if ($null -ne $this.PrintedPageCount) {"Pages: $($this.PrintedPageCount)"} else {'Printer'}</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMPrinterSystemInfo</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>"$($this.Manufacturer) $($this.Model)"</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMPrinterSnmpInfo</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>if ($this.SnmpName) {$this.SnmpName} elseif ($this.ObjectId) {$this.ObjectId} else {'SNMP'}</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMPrinterMarkerSupply</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $Desc = if ($this.Description) {$this.Description} else {'Supply'}
          $Level = if ($this.SuppliesLevel) {" [$($this.SuppliesLevel)]"} else {''}
          "$Desc$Level"
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- Site Domain                                                           -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->

  <Type>
    <Name>DRMMSite</Name>
    <Members>
      <AliasProperty>
        <Name>SiteUid</Name>
        <ReferencedMemberName>Uid</ReferencedMemberName>
      </AliasProperty>
      <AliasProperty>
        <Name>SiteId</Name>
        <ReferencedMemberName>Id</ReferencedMemberName>
      </AliasProperty>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>$this.GetSummary()</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeletedDevicesSite</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $SiteName = if ($this.Name) {$this.Name} else {'Deleted Site'}
          "$SiteName (Deleted)"
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMSiteSettings</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>$this.GetSummary()</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMSiteGeneralSettings</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>$this.GetSummary()</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMSiteProxySettings</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>$this.GetSummary()</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMSiteMailRecipient</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $RecipName = if ($this.Name) {$this.Name} else {'Recipient'}
          $Email = if ($this.Email) {" &lt;$($this.Email)&gt;"} else {''}
          "$RecipName$Email"
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDevicesStatus</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>$this.GetSummary()</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- Status Domain                                                         -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->

  <Type>
    <Name>DRMMStatus</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>"$($this.Status) v$($this.Version)"</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- User Domain                                                           -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->

  <Type>
    <Name>DRMMUser</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>$this.GetSummary()</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- Variable Domain                                                       -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->

  <Type>
    <Name>DRMMVariable</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>$this.GetSummary()</Script>
      </ScriptMethod>
    </Members>
  </Type>

</Types>

