  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- Device Domain                                                         -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->

  <Type>
    <Name>DRMMDevice</Name>
    <Members>
      <AliasProperty>
        <Name>DeviceUid</Name>
        <ReferencedMemberName>Uid</ReferencedMemberName>
      </AliasProperty>
      <AliasProperty>
        <Name>DeviceId</Name>
        <ReferencedMemberName>Id</ReferencedMemberName>
      </AliasProperty>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>$this.GetSummary()</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceAntivirusInfo</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>$this.GetSummary()</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceNetworkInterface</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>"$($this.Hostname) ($($this.IntIpAddress))"</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDevicePatchManagement</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $Status = if ($this.PatchStatus) {$this.PatchStatus} else {'Unknown'}
          $Pending = if ($null -ne $this.PatchesApprovedPending) {" Pending:$($this.PatchesApprovedPending)"} else {''}
          $Installed = if ($null -ne $this.PatchesInstalled) {" Installed:$($this.PatchesInstalled)"} else {''}
          "$Status$Pending$Installed"
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceType</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>"$($this.Category)/$($this.Type)"</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceUdfs</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $Set = 0
          for ($i = 1; $i -le 30; $i++) {
            $Val = $this."Udf$i"
            if (-not [string]::IsNullOrWhiteSpace($Val)) {$Set++}
          }
          "$Set of 30 UDFs set"
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- Device Audit Domain                                                   -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->

  <Type>
    <Name>DRMMDeviceAudit</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $Sys = if ($this.SystemInfo) {"$($this.SystemInfo.Manufacturer) $($this.SystemInfo.Model)"} else {''}
          if ($Sys) {"$($this.DeviceUid) - $Sys"} else {"$($this.DeviceUid)"}
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceAuditSystemInfo</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>"$($this.Manufacturer) $($this.Model)"</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceAuditBios</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>"$($this.Manufacturer) $($this.Name)"</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceAuditBaseBoard</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>"$($this.Manufacturer) $($this.Product)"</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceAuditDisplay</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>"$($this.Instance) ($($this.ScreenWidth)x$($this.ScreenHeight))"</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceAuditLogicalDisk</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $FreeGb = [math]::Round($this.Freespace / 1GB, 1)
          $SizeGb = [math]::Round($this.Size / 1GB, 1)
          "$($this.DiskIdentifier) ${FreeGb}GB free / ${SizeGb}GB"
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceAuditMobileInfo</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>if ($this.Number) {$this.Number} elseif ($this.Imei) {$this.Imei} else {'Mobile'}</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceAuditPhysicalMemory</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $CapGb = if ($this.Capacity -gt 0) {[math]::Round($this.Capacity / 1GB, 1)} else {0}
          "$($this.Manufacturer) $($this.BankLabel) ${CapGb}GB"
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceAuditProcessor</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>if ($this.Name) {$this.Name} else {'Processor'}</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceAuditSnmpInfo</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>if ($this.Name) {$this.Name} elseif ($this.Description) {$this.Description} else {'SNMP'}</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceAuditSoftware</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>"$($this.Name) $($this.Version)"</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceAuditVideoBoard</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>if ($this.DisplayAdapter) {$this.DisplayAdapter} else {'VideoBoard'}</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMDeviceAuditAttachedDevice</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>if ($this.Description) {$this.Description} elseif ($this.Instance) {$this.Instance} else {'AttachedDevice'}</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- ESXi Host Audit Domain                                                -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->

  <Type>
    <Name>DRMMEsxiHostAudit</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $Sys = if ($this.SystemInfo) {"$($this.SystemInfo.Manufacturer) $($this.SystemInfo.Model)"} else {''}
          if ($Sys) {"$($this.DeviceUid) - $Sys"} else {"$($this.DeviceUid)"}
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMEsxiSystemInfo</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>"$($this.Manufacturer) $($this.Model)"</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMEsxiGuest</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>if ($this.GuestName) {$this.GuestName} else {'Guest'}</Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMEsxiDatastore</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $Name = if ($this.DatastoreName) {$this.DatastoreName} else {'Datastore'}
          $Status = if ($this.Status) {" [$($this.Status)]"} else {''}
          "$Name$Status"
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMEsxiNic</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $NicName = if ($this.Name) {$this.Name} else {'NIC'}
          $Ip = if ($this.Ipv4) {" ($($this.Ipv4))"} else {''}
          "$NicName$Ip"
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMEsxiPhysicalMemory</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $Mod = if ($this.Module) {$this.Module} else {'Memory'}
          $SizeGb = if ($this.Size -and $this.Size -gt 0) {" $([math]::Round($this.Size / 1GB, 1))GB"} else {''}
          "$Mod$SizeGb"
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

  <Type>
    <Name>DRMMEsxiProcessor</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>
          $ProcName = if ($this.Name) {$this.Name} else {'Processor'}
          $Cores = if ($this.NumberOfCores) {" ($($this.NumberOfCores) cores)"} else {''}
          "$ProcName$Cores"
        </Script>
      </ScriptMethod>
    </Members>
  </Type>

