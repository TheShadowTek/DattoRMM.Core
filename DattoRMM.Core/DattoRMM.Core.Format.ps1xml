              <ListItem><Label>ProxySettings</Label><ScriptBlock>if ($_.ProxySettings) {$_.ProxySettings.GetSummary()} else {'None'}</ScriptBlock></ListItem>
              <ListItem><Label>MailRecipients</Label><ScriptBlock>if ($_.MailRecipients) {($_.MailRecipients | ForEach-Object {$_.ToString()}) -join '; '} else {''}</ScriptBlock></ListItem>
