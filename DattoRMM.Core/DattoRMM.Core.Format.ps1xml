<?xml version="1.0" encoding="utf-8"?>
<!-- SPDX-License-Identifier: MPL-2.0 -->
<!-- DattoRMM.Core v2 Format - Comprehensive List (default) and Table (OGV) views -->
<!-- Load with: Update-FormatData -PrependPath .\DattoRMM.Core.v2.Format.ps1xml -->
<Configuration>
  <ViewDefinitions>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- Account Domain                                                      -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <View>
      <Name>DRMMAccount.List</Name>
      <ViewSelectedBy><TypeName>DRMMAccount</TypeName></ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem><Label>Name</Label><PropertyName>Name</PropertyName></ListItem>
              <ListItem><Label>Uid</Label><PropertyName>Uid</PropertyName></ListItem>
              <ListItem><Label>Id</Label><PropertyName>Id</PropertyName></ListItem>
              <ListItem><Label>Currency</Label><PropertyName>Currency</PropertyName></ListItem>
              <ListItem><Label>Descriptor</Label><ScriptBlock>if ($_.Descriptor) {"$($_.Descriptor.BillingEmail) | Limit: $($_.Descriptor.DeviceLimit) | TZ: $($_.Descriptor.TimeZone)"} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>DevicesStatus</Label><ScriptBlock>if ($_.DevicesStatus) {$_.DevicesStatus.GetSummary()} else {''}</ScriptBlock></ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

    <View>
      <Name>DRMMAccount.Table</Name>
      <ViewSelectedBy><TypeName>DRMMAccount</TypeName></ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>Name</Label><Width>30</Width></TableColumnHeader>
          <TableColumnHeader><Label>Uid</Label><Width>36</Width></TableColumnHeader>
          <TableColumnHeader><Label>Id</Label><Width>8</Width></TableColumnHeader>
          <TableColumnHeader><Label>Currency</Label><Width>8</Width></TableColumnHeader>
          <TableColumnHeader><Label>DevicesStatus</Label><Width>40</Width></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>Name</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Uid</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Id</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Currency</PropertyName></TableColumnItem>
              <TableColumnItem><ScriptBlock>if ($_.DevicesStatus) {$_.DevicesStatus.GetSummary()} else {''}</ScriptBlock></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <View>
      <Name>DRMMAccountDescriptor.List</Name>
      <ViewSelectedBy><TypeName>DRMMAccountDescriptor</TypeName></ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem><Label>BillingEmail</Label><PropertyName>BillingEmail</PropertyName></ListItem>
              <ListItem><Label>DeviceLimit</Label><PropertyName>DeviceLimit</PropertyName></ListItem>
              <ListItem><Label>TimeZone</Label><PropertyName>TimeZone</PropertyName></ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

    <View>
      <Name>DRMMAccountDevicesStatus.List</Name>
      <ViewSelectedBy><TypeName>DRMMAccountDevicesStatus</TypeName></ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem><Label>NumberOfDevices</Label><PropertyName>NumberOfDevices</PropertyName></ListItem>
              <ListItem><Label>NumberOfOnlineDevices</Label><PropertyName>NumberOfOnlineDevices</PropertyName></ListItem>
              <ListItem><Label>NumberOfOfflineDevices</Label><PropertyName>NumberOfOfflineDevices</PropertyName></ListItem>
              <ListItem><Label>NumberOfOnDemandDevices</Label><PropertyName>NumberOfOnDemandDevices</PropertyName></ListItem>
              <ListItem><Label>NumberOfManagedDevices</Label><PropertyName>NumberOfManagedDevices</PropertyName></ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

    <View>
      <Name>DRMMAccountDevicesStatus.Table</Name>
      <ViewSelectedBy><TypeName>DRMMAccountDevicesStatus</TypeName></ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>Total</Label><Width>8</Width></TableColumnHeader>
          <TableColumnHeader><Label>Online</Label><Width>8</Width></TableColumnHeader>
          <TableColumnHeader><Label>Offline</Label><Width>8</Width></TableColumnHeader>
          <TableColumnHeader><Label>OnDemand</Label><Width>10</Width></TableColumnHeader>
          <TableColumnHeader><Label>Managed</Label><Width>10</Width></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>NumberOfDevices</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>NumberOfOnlineDevices</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>NumberOfOfflineDevices</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>NumberOfOnDemandDevices</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>NumberOfManagedDevices</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- Activity Log Domain                                                 -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <View>
      <Name>DRMMActivityLog.List</Name>
      <ViewSelectedBy><TypeName>DRMMActivityLog</TypeName></ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem><Label>Id</Label><PropertyName>Id</PropertyName></ListItem>
              <ListItem><Label>Date</Label><PropertyName>Date</PropertyName></ListItem>
              <ListItem><Label>Entity</Label><PropertyName>Entity</PropertyName></ListItem>
              <ListItem><Label>Category</Label><PropertyName>Category</PropertyName></ListItem>
              <ListItem><Label>Action</Label><PropertyName>Action</PropertyName></ListItem>
              <ListItem><Label>Hostname</Label><PropertyName>Hostname</PropertyName></ListItem>
              <ListItem><Label>DeviceId</Label><PropertyName>DeviceId</PropertyName></ListItem>
              <ListItem><Label>Site</Label><ScriptBlock>if ($_.Site) {"$($_.Site.Name) (Id: $($_.Site.Id))"} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>User</Label><ScriptBlock>if ($_.User) {$_.User.GetSummary()} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>HasStdOut</Label><PropertyName>HasStdOut</PropertyName></ListItem>
              <ListItem><Label>HasStdErr</Label><PropertyName>HasStdErr</PropertyName></ListItem>
              <ListItem><Label>Details</Label><ScriptBlock>if ($_.Details) {$_.Details.ToString()} else {''}</ScriptBlock></ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

    <View>
      <Name>DRMMActivityLog.Table</Name>
      <ViewSelectedBy><TypeName>DRMMActivityLog</TypeName></ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>Id</Label><Width>24</Width></TableColumnHeader>
          <TableColumnHeader><Label>Date</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>Entity</Label><Width>10</Width></TableColumnHeader>
          <TableColumnHeader><Label>Category</Label><Width>12</Width></TableColumnHeader>
          <TableColumnHeader><Label>Action</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>Hostname</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>Site</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>User</Label><Width>25</Width></TableColumnHeader>
          <TableColumnHeader><Label>StdOut</Label><Width>6</Width></TableColumnHeader>
          <TableColumnHeader><Label>StdErr</Label><Width>6</Width></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>Id</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Date</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Entity</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Category</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Action</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Hostname</PropertyName></TableColumnItem>
              <TableColumnItem><ScriptBlock>if ($_.Site) {$_.Site.Name} else {''}</ScriptBlock></TableColumnItem>
              <TableColumnItem><ScriptBlock>if ($_.User) {$_.User.GetSummary()} else {''}</ScriptBlock></TableColumnItem>
              <TableColumnItem><PropertyName>HasStdOut</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>HasStdErr</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <View>
      <Name>DRMMActivityLogSite.List</Name>
      <ViewSelectedBy><TypeName>DRMMActivityLogSite</TypeName></ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem><Label>Id</Label><PropertyName>Id</PropertyName></ListItem>
              <ListItem><Label>Name</Label><PropertyName>Name</PropertyName></ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

    <View>
      <Name>DRMMActivityLogUser.List</Name>
      <ViewSelectedBy><TypeName>DRMMActivityLogUser</TypeName></ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem><Label>Id</Label><PropertyName>Id</PropertyName></ListItem>
              <ListItem><Label>UserName</Label><PropertyName>UserName</PropertyName></ListItem>
              <ListItem><Label>FirstName</Label><PropertyName>FirstName</PropertyName></ListItem>
              <ListItem><Label>LastName</Label><PropertyName>LastName</PropertyName></ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- Alert Domain                                                        -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <View>
      <Name>DRMMAlert.List</Name>
      <ViewSelectedBy><TypeName>DRMMAlert</TypeName></ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem><Label>AlertUid</Label><PropertyName>AlertUid</PropertyName></ListItem>
              <ListItem><Label>Priority</Label><PropertyName>Priority</PropertyName></ListItem>
              <ListItem><Label>Diagnostics</Label><PropertyName>Diagnostics</PropertyName></ListItem>
              <ListItem><Label>Resolved</Label><PropertyName>Resolved</PropertyName></ListItem>
              <ListItem><Label>ResolvedBy</Label><PropertyName>ResolvedBy</PropertyName></ListItem>
              <ListItem><Label>ResolvedOn</Label><PropertyName>ResolvedOn</PropertyName></ListItem>
              <ListItem><Label>Muted</Label><PropertyName>Muted</PropertyName></ListItem>
              <ListItem><Label>TicketNumber</Label><PropertyName>TicketNumber</PropertyName></ListItem>
              <ListItem><Label>Timestamp</Label><PropertyName>Timestamp</PropertyName></ListItem>
              <ListItem><Label>AutoresolveMins</Label><PropertyName>AutoresolveMins</PropertyName></ListItem>
              <ListItem><Label>PortalUrl</Label><PropertyName>PortalUrl</PropertyName></ListItem>
              <ListItem><Label>AlertMonitorInfo</Label><ScriptBlock>if ($_.AlertMonitorInfo) {$_.AlertMonitorInfo.GetSummary()} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>AlertContext</Label><ScriptBlock>if ($_.AlertContext) {$_.AlertContext.ToString()} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>AlertSourceInfo</Label><ScriptBlock>if ($_.AlertSourceInfo) {$_.AlertSourceInfo.GetSummary()} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>ResponseActions</Label><ScriptBlock>if ($_.ResponseActions) {($_.ResponseActions | ForEach-Object {$_.GetSummary()}) -join '; '} else {''}</ScriptBlock></ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

    <View>
      <Name>DRMMAlert.Table</Name>
      <ViewSelectedBy><TypeName>DRMMAlert</TypeName></ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>AlertUid</Label><Width>36</Width></TableColumnHeader>
          <TableColumnHeader><Label>Priority</Label><Width>10</Width></TableColumnHeader>
          <TableColumnHeader><Label>Diagnostics</Label><Width>40</Width></TableColumnHeader>
          <TableColumnHeader><Label>Resolved</Label><Width>8</Width></TableColumnHeader>
          <TableColumnHeader><Label>Muted</Label><Width>6</Width></TableColumnHeader>
          <TableColumnHeader><Label>Timestamp</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>TicketNumber</Label><Width>15</Width></TableColumnHeader>
          <TableColumnHeader><Label>Source</Label><Width>30</Width></TableColumnHeader>
          <TableColumnHeader><Label>Monitor</Label><Width>25</Width></TableColumnHeader>
          <TableColumnHeader><Label>Context</Label><Width>30</Width></TableColumnHeader>
          <TableColumnHeader><Label>ResolvedBy</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>ResolvedOn</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>AutoresolveMins</Label><Width>15</Width></TableColumnHeader>
          <TableColumnHeader><Label>ResponseActions</Label><Width>30</Width></TableColumnHeader>
          <TableColumnHeader><Label>PortalUrl</Label><Width>60</Width></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>AlertUid</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Priority</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Diagnostics</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Resolved</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Muted</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Timestamp</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>TicketNumber</PropertyName></TableColumnItem>
              <TableColumnItem><ScriptBlock>if ($_.AlertSourceInfo) {$_.AlertSourceInfo.GetSummary()} else {''}</ScriptBlock></TableColumnItem>
              <TableColumnItem><ScriptBlock>if ($_.AlertMonitorInfo) {$_.AlertMonitorInfo.GetSummary()} else {''}</ScriptBlock></TableColumnItem>
              <TableColumnItem><ScriptBlock>if ($_.AlertContext) {$_.AlertContext.ToString()} else {''}</ScriptBlock></TableColumnItem>
              <TableColumnItem><PropertyName>ResolvedBy</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>ResolvedOn</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>AutoresolveMins</PropertyName></TableColumnItem>
              <TableColumnItem><ScriptBlock>if ($_.ResponseActions) {($_.ResponseActions | ForEach-Object {$_.GetSummary()}) -join '; '} else {''}</ScriptBlock></TableColumnItem>
              <TableColumnItem><PropertyName>PortalUrl</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <View>
      <Name>DRMMAlertMonitorInfo.List</Name>
      <ViewSelectedBy><TypeName>DRMMAlertMonitorInfo</TypeName></ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem><Label>SendsEmails</Label><PropertyName>SendsEmails</PropertyName></ListItem>
              <ListItem><Label>CreatesTicket</Label><PropertyName>CreatesTicket</PropertyName></ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

    <View>
      <Name>DRMMAlertSourceInfo.List</Name>
      <ViewSelectedBy><TypeName>DRMMAlertSourceInfo</TypeName></ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem><Label>DeviceName</Label><PropertyName>DeviceName</PropertyName></ListItem>
              <ListItem><Label>DeviceUid</Label><PropertyName>DeviceUid</PropertyName></ListItem>
              <ListItem><Label>SiteName</Label><PropertyName>SiteName</PropertyName></ListItem>
              <ListItem><Label>SiteUid</Label><PropertyName>SiteUid</PropertyName></ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

    <View>
      <Name>DRMMAlertResponseAction.List</Name>
      <ViewSelectedBy><TypeName>DRMMAlertResponseAction</TypeName></ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem><Label>ActionType</Label><PropertyName>ActionType</PropertyName></ListItem>
              <ListItem><Label>Description</Label><PropertyName>Description</PropertyName></ListItem>
              <ListItem><Label>ActionTime</Label><PropertyName>ActionTime</PropertyName></ListItem>
              <ListItem><Label>ActionReference</Label><PropertyName>ActionReference</PropertyName></ListItem>
              <ListItem><Label>ActionReferenceInt</Label><PropertyName>ActionReferenceInt</PropertyName></ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

    <View>
      <Name>DRMMAlertResponseAction.Table</Name>
      <ViewSelectedBy><TypeName>DRMMAlertResponseAction</TypeName></ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>ActionType</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>Description</Label><Width>40</Width></TableColumnHeader>
          <TableColumnHeader><Label>ActionTime</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>ActionReference</Label><Width>30</Width></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>ActionType</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Description</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>ActionTime</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>ActionReference</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- Component Domain                                                    -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <View>
      <Name>DRMMComponent.List</Name>
      <ViewSelectedBy><TypeName>DRMMComponent</TypeName></ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem><Label>Name</Label><PropertyName>Name</PropertyName></ListItem>
              <ListItem><Label>Uid</Label><PropertyName>Uid</PropertyName></ListItem>
              <ListItem><Label>Id</Label><PropertyName>Id</PropertyName></ListItem>
              <ListItem><Label>Description</Label><PropertyName>Description</PropertyName></ListItem>
              <ListItem><Label>CategoryCode</Label><PropertyName>CategoryCode</PropertyName></ListItem>
              <ListItem><Label>CredentialsRequired</Label><PropertyName>CredentialsRequired</PropertyName></ListItem>
              <ListItem><Label>Variables</Label><ScriptBlock>if ($_.Variables) {"$($_.Variables.Count) variable(s)"} else {'0'}</ScriptBlock></ListItem>
              <ListItem><Label>PortalUrl</Label><PropertyName>PortalUrl</PropertyName></ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

    <View>
      <Name>DRMMComponent.Table</Name>
      <ViewSelectedBy><TypeName>DRMMComponent</TypeName></ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>Name</Label><Width>30</Width></TableColumnHeader>
          <TableColumnHeader><Label>Uid</Label><Width>36</Width></TableColumnHeader>
          <TableColumnHeader><Label>Id</Label><Width>8</Width></TableColumnHeader>
          <TableColumnHeader><Label>CategoryCode</Label><Width>15</Width></TableColumnHeader>
          <TableColumnHeader><Label>CredReq</Label><Width>8</Width></TableColumnHeader>
          <TableColumnHeader><Label>Vars</Label><Width>6</Width></TableColumnHeader>
          <TableColumnHeader><Label>Description</Label><Width>40</Width></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>Name</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Uid</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Id</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>CategoryCode</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>CredentialsRequired</PropertyName></TableColumnItem>
              <TableColumnItem><ScriptBlock>if ($_.Variables) {$_.Variables.Count} else {0}</ScriptBlock></TableColumnItem>
              <TableColumnItem><PropertyName>Description</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <View>
      <Name>DRMMComponentVariable.List</Name>
      <ViewSelectedBy><TypeName>DRMMComponentVariable</TypeName></ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem><Label>Name</Label><PropertyName>Name</PropertyName></ListItem>
              <ListItem><Label>Type</Label><PropertyName>Type</PropertyName></ListItem>
              <ListItem><Label>Direction</Label><ScriptBlock>if ($_.Direction) {'Input'} else {'Output'}</ScriptBlock></ListItem>
              <ListItem><Label>DefaultValue</Label><PropertyName>DefaultValue</PropertyName></ListItem>
              <ListItem><Label>Description</Label><PropertyName>Description</PropertyName></ListItem>
              <ListItem><Label>Index</Label><PropertyName>Index</PropertyName></ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

    <View>
      <Name>DRMMComponentVariable.Table</Name>
      <ViewSelectedBy><TypeName>DRMMComponentVariable</TypeName></ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>Name</Label><Width>25</Width></TableColumnHeader>
          <TableColumnHeader><Label>Type</Label><Width>12</Width></TableColumnHeader>
          <TableColumnHeader><Label>Direction</Label><Width>8</Width></TableColumnHeader>
          <TableColumnHeader><Label>DefaultValue</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>Description</Label><Width>40</Width></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>Name</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Type</PropertyName></TableColumnItem>
              <TableColumnItem><ScriptBlock>if ($_.Direction) {'Input'} else {'Output'}</ScriptBlock></TableColumnItem>
              <TableColumnItem><PropertyName>DefaultValue</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Description</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!-- Device Domain                                                       -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <View>
      <Name>DRMMDevice.List</Name>
      <ViewSelectedBy><TypeName>DRMMDevice</TypeName></ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem><Label>Hostname</Label><PropertyName>Hostname</PropertyName></ListItem>
              <ListItem><Label>Uid</Label><PropertyName>Uid</PropertyName></ListItem>
              <ListItem><Label>Id</Label><PropertyName>Id</PropertyName></ListItem>
              <ListItem><Label>SiteName</Label><PropertyName>SiteName</PropertyName></ListItem>
              <ListItem><Label>SiteUid</Label><PropertyName>SiteUid</PropertyName></ListItem>
              <ListItem><Label>DeviceType</Label><ScriptBlock>if ($_.DeviceType) {"$($_.DeviceType.Category)/$($_.DeviceType.Type)"} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>Online</Label><PropertyName>Online</PropertyName></ListItem>
              <ListItem><Label>OperatingSystem</Label><PropertyName>OperatingSystem</PropertyName></ListItem>
              <ListItem><Label>IntIpAddress</Label><PropertyName>IntIpAddress</PropertyName></ListItem>
              <ListItem><Label>ExtIpAddress</Label><PropertyName>ExtIpAddress</PropertyName></ListItem>
              <ListItem><Label>Domain</Label><PropertyName>Domain</PropertyName></ListItem>
              <ListItem><Label>LastLoggedInUser</Label><PropertyName>LastLoggedInUser</PropertyName></ListItem>
              <ListItem><Label>LastSeen</Label><PropertyName>LastSeen</PropertyName></ListItem>
              <ListItem><Label>LastReboot</Label><PropertyName>LastReboot</PropertyName></ListItem>
              <ListItem><Label>LastAuditDate</Label><PropertyName>LastAuditDate</PropertyName></ListItem>
              <ListItem><Label>CreationDate</Label><PropertyName>CreationDate</PropertyName></ListItem>
              <ListItem><Label>Description</Label><PropertyName>Description</PropertyName></ListItem>
              <ListItem><Label>CagVersion</Label><PropertyName>CagVersion</PropertyName></ListItem>
              <ListItem><Label>A64Bit</Label><PropertyName>A64Bit</PropertyName></ListItem>
              <ListItem><Label>RebootRequired</Label><PropertyName>RebootRequired</PropertyName></ListItem>
              <ListItem><Label>Suspended</Label><PropertyName>Suspended</PropertyName></ListItem>
              <ListItem><Label>Deleted</Label><PropertyName>Deleted</PropertyName></ListItem>
              <ListItem><Label>SnmpEnabled</Label><PropertyName>SnmpEnabled</PropertyName></ListItem>
              <ListItem><Label>NetworkProbe</Label><PropertyName>NetworkProbe</PropertyName></ListItem>
              <ListItem><Label>DeviceClass</Label><PropertyName>DeviceClass</PropertyName></ListItem>
              <ListItem><Label>SoftwareStatus</Label><PropertyName>SoftwareStatus</PropertyName></ListItem>
              <ListItem><Label>WarrantyDate</Label><PropertyName>WarrantyDate</PropertyName></ListItem>
              <ListItem><Label>Antivirus</Label><ScriptBlock>if ($_.Antivirus) {$_.Antivirus.GetSummary()} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>PatchManagement</Label><ScriptBlock>if ($_.PatchManagement) {$_.PatchManagement.ToString()} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>Udfs</Label><ScriptBlock>if ($_.Udfs) {$_.Udfs.ToString()} else {''}</ScriptBlock></ListItem>
