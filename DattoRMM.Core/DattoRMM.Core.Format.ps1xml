    <!-- Site Domain                                                         -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <View>
      <Name>DRMMSite.List</Name>
      <ViewSelectedBy><TypeName>DRMMSite</TypeName></ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem><Label>Name</Label><PropertyName>Name</PropertyName></ListItem>
              <ListItem><Label>Uid</Label><PropertyName>Uid</PropertyName></ListItem>
              <ListItem><Label>Id</Label><PropertyName>Id</PropertyName></ListItem>
              <ListItem><Label>Description</Label><PropertyName>Description</PropertyName></ListItem>
              <ListItem><Label>Notes</Label><PropertyName>Notes</PropertyName></ListItem>
              <ListItem><Label>OnDemand</Label><PropertyName>OnDemand</PropertyName></ListItem>
              <ListItem><Label>SplashtopAutoInstall</Label><PropertyName>SplashtopAutoInstall</PropertyName></ListItem>
              <ListItem><Label>DevicesStatus</Label><ScriptBlock>if ($_.DevicesStatus) {$_.DevicesStatus.GetSummary()} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>ProxySettings</Label><ScriptBlock>if ($_.ProxySettings) {$_.ProxySettings.GetSummary()} else {'None'}</ScriptBlock></ListItem>
              <ListItem><Label>SiteSettings</Label><ScriptBlock>if ($_.SiteSettings) {$_.SiteSettings.GetSummary()} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>AutotaskCompanyName</Label><PropertyName>AutotaskCompanyName</PropertyName></ListItem>
              <ListItem><Label>AutotaskCompanyId</Label><PropertyName>AutotaskCompanyId</PropertyName></ListItem>
              <ListItem><Label>Variables</Label><ScriptBlock>if ($_.Variables) {"$($_.Variables.Count) variable(s)"} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>Filters</Label><ScriptBlock>if ($_.Filters) {"$($_.Filters.Count) filter(s)"} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>PortalUrl</Label><PropertyName>PortalUrl</PropertyName></ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

    <View>
      <Name>DRMMSite.Table</Name>
      <ViewSelectedBy><TypeName>DRMMSite</TypeName></ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>Name</Label><Width>25</Width></TableColumnHeader>
          <TableColumnHeader><Label>Uid</Label><Width>36</Width></TableColumnHeader>
          <TableColumnHeader><Label>Id</Label><Width>8</Width></TableColumnHeader>
