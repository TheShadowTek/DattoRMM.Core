            <TableColumnItems>
              <TableColumnItem><PropertyName>Name</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Uid</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Id</PropertyName></TableColumnItem>
              <TableColumnItem><ScriptBlock>if ($_.DevicesStatus) {$_.DevicesStatus.GetSummary()} else {''}</ScriptBlock></TableColumnItem>
              <TableColumnItem><PropertyName>OnDemand</PropertyName></TableColumnItem>
              <TableColumnItem><ScriptBlock>if ($_.ProxySettings) {$_.ProxySettings.GetSummary()} else {'None'}</ScriptBlock></TableColumnItem>
              <TableColumnItem><PropertyName>Description</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>PortalUrl</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

