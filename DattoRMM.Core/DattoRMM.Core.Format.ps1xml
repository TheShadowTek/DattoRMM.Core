              <TableColumnItem><ScriptBlock>if ($_.SnmpInfo) {$_.SnmpInfo.ToString()} else {''}</ScriptBlock></TableColumnItem>
              <TableColumnItem><ScriptBlock>if ($_.Printer -and $null -ne $_.Printer.PrintedPageCount) {$_.Printer.PrintedPageCount} else {''}</ScriptBlock></TableColumnItem>
              <TableColumnItem><ScriptBlock>if ($_.PrinterMarkerSupplies) {$_.PrinterMarkerSupplies.Count} else {0}</ScriptBlock></TableColumnItem>
              <TableColumnItem><ScriptBlock>if ($_.Nics) {$_.Nics.Count} else {0}</ScriptBlock></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
