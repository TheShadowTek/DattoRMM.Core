              <ListItem><Label>SystemInfo</Label><ScriptBlock>if ($_.SystemInfo) {$_.SystemInfo.ToString()} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>SnmpInfo</Label><ScriptBlock>if ($_.SnmpInfo) {$_.SnmpInfo.ToString()} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>Printer</Label><ScriptBlock>if ($_.Printer) {$_.Printer.ToString()} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>PrinterMarkerSupplies</Label><ScriptBlock>if ($_.PrinterMarkerSupplies) {($_.PrinterMarkerSupplies | ForEach-Object {$_.ToString()}) -join '; '} else {''}</ScriptBlock></ListItem>
              <ListItem><Label>Nics</Label><ScriptBlock>if ($_.Nics) {"$($_.Nics.Count) interface(s)"} else {''}</ScriptBlock></ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

