<!-- DRMMStatus domain Type extensions -->
<Types>

  <Type>
    <Name>DRMMStatus</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>"$($this.Status) v$($this.Version)"</Script>
      </ScriptMethod>
    </Members>
  </Type>

</Types>
