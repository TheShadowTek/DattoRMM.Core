<!-- DRMMStatus domain Format views -->
<Configuration>
  <ViewDefinitions>

    <View>
      <Name>DRMMStatus.List</Name>
      <ViewSelectedBy>
        <TypeName>DRMMStatus</TypeName>
      </ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem>
                <Label>Status</Label>
                <PropertyName>Status</PropertyName>
              </ListItem>
              <ListItem>
                <Label>Version</Label>
                <PropertyName>Version</PropertyName>
              </ListItem>
              <ListItem>
                <Label>Started</Label>
                <PropertyName>Started</PropertyName>
              </ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>

  </ViewDefinitions>
</Configuration>
