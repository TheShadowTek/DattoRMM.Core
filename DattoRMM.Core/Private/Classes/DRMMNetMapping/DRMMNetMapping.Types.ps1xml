<!-- DRMMNetMapping domain Type extensions -->
<Types>

  <Type>
    <Name>DRMMNetMapping</Name>
    <Members>
      <ScriptMethod>
        <Name>ToString</Name>
        <Script>if ($this.Name) {$this.Name} else {"NetMapping $($this.Uid)"}</Script>
      </ScriptMethod>
    </Members>
  </Type>

</Types>